# .env.example
# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# ============================================================================
# AMBIENTE DE PRODUÇÃO
# ============================================================================

# Database
POSTGRES_DB=unbot_delivery
POSTGRES_USER=unbot
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# Gateway API
GATEWAY_PORT=8080

# Mobile Web
WEB_PORT=80
API_BASE_URL=https://your-domain.com

# MQTT Broker
MQTT_HOST=your-mqtt-broker.com
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password

# ============================================================================
# NOTAS
# ============================================================================
# 
# Para desenvolvimento local, use docker-compose.dev.yml que já tem valores padrão
# Para produção, use docker-compose.prod.yml com este arquivo .env
# Para testes, use docker-compose.test.yml (não precisa de .env)