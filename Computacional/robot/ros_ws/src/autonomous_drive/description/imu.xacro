<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="imu_x" value="0.15"/>
    <xacro:property name="imu_y" value="0.0"/>
    <xacro:property name="imu_z" value="0.075"/>

    <xacro:property name="imu_update_rate" value="100"/>
    <xacro:property name="imu_gyro_stddev" value="0.009"/>
    <xacro:property name="imu_accel_stddev" value="0.021"/>
    <xacro:property name="imu_topic" value="/demo/imu"/>

    <joint name="imu_joint" type="fixed">
        <parent link="chassi"/>
        <child link="imu_frame"/>
        <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="0 0 0"/>
    </joint>

    <link name="imu_frame">
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="0.000001" ixy="0" ixz="0"
                     iyy="0.000001" iyz="0"
                     izz="0.000001"/>
        </inertial>
    </link>

</robot>